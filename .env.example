# PostgreSQL Container Configuration
POSTGRES_USER=indexer_user
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=eth_indexer

# Go Application Environment Variables
# Note: 'postgres' is used as the host name because it matches the service name in docker-compose
DATABASE_URL=postgres://indexer_user:change_this_to_a_secure_password@postgres:5432/eth_indexer?sslmode=disable
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY